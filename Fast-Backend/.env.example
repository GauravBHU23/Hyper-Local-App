APP_NAME=HyperLocal API
APP_DESCRIPTION=Smart Local Services Finder with AI
APP_VERSION=1.0.0
APP_ENV=development
BACKEND_PUBLIC_URL=http://127.0.0.1:8001

DATABASE_URL=postgresql://postgres:password@localhost:5432/hyperlocal
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://your-frontend-domain.vercel.app"]
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
ADMIN_EMAILS=["admin@hyperlocal.dev"]

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_URL=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_PLACES_AUTOCOMPLETE_API_URL=https://places.googleapis.com/v1/places:autocomplete

REDIS_URL=redis://localhost:6379

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
UPI_PAYMENT_ID=
UPI_PAYMENT_NAME=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
MAIL_FROM_NAME=HyperLocal Support
SMTP_USE_TLS=true
EMAIL_OTP_EXPIRE_MINUTES=10

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
MAX_UPLOAD_BYTES=5242880
ALLOWED_UPLOAD_EXTENSIONS=[".jpg",".jpeg",".png",".pdf",".webp"]
